{
  "meta": {
    "version": "1.0",
    "character": "Loke",
    "description": "Rive rigging blueprint for Loke, a child safari explorer based on supplied reference art.",
    "target_artboard_name": "Loke",
    "target_state_machine": "LokeStateMachine"
  },
  "import_assets": {
    "svg_parts": [
      { "file": "assets/characters/loke/svg/loke_shadow.svg", "layer_name": "shadow" },
      { "file": "assets/characters/loke/svg/loke_backpack.svg", "layer_name": "backpack" },
      { "file": "assets/characters/loke/svg/loke_leg_left.svg", "layer_name": "leg_left" },
      { "file": "assets/characters/loke/svg/loke_leg_right.svg", "layer_name": "leg_right" },
      { "file": "assets/characters/loke/svg/loke_shoe_left.svg", "layer_name": "shoe_left" },
      { "file": "assets/characters/loke/svg/loke_shoe_right.svg", "layer_name": "shoe_right" },
      { "file": "assets/characters/loke/svg/loke_torso.svg", "layer_name": "torso" },
      { "file": "assets/characters/loke/svg/loke_arm_left.svg", "layer_name": "arm_left" },
      { "file": "assets/characters/loke/svg/loke_arm_right.svg", "layer_name": "arm_right" },
      { "file": "assets/characters/loke/svg/loke_head.svg", "layer_name": "head" },
      { "file": "assets/characters/loke/svg/loke_eyes_open.svg", "layer_name": "eyes_open" },
      { "file": "assets/characters/loke/svg/loke_eyes_blink.svg", "layer_name": "eyes_blink" },
      { "file": "assets/characters/loke/svg/loke_mouth_neutral.svg", "layer_name": "mouth_neutral" },
      { "file": "assets/characters/loke/svg/loke_mouth_happy.svg", "layer_name": "mouth_happy" },
      { "file": "assets/characters/loke/svg/loke_mouth_sad.svg", "layer_name": "mouth_sad" },
      { "file": "assets/characters/loke/svg/loke_hat.svg", "layer_name": "hat" }
    ],
    "import_order": [
      "shadow",
      "backpack",
      "legs",
      "shoes",
      "torso",
      "arms",
      "head",
      "eyes",
      "mouth",
      "hat"
    ]
  },
  "artboard": {
    "name": "Loke",
    "width": 400,
    "height": 600,
    "origin": { "x": 200, "y": 520 }
  },
  "bones": {
    "bones": [
      { "name": "root", "parent": null, "position": { "x": 200, "y": 520 }, "bind_mesh": "torso" },
      { "name": "spine", "parent": "root", "position": { "x": 200, "y": 360 }, "bind_mesh": "torso" },
      { "name": "chest", "parent": "spine", "position": { "x": 200, "y": 280 }, "bind_mesh": "torso" },
      { "name": "head", "parent": "chest", "position": { "x": 200, "y": 165 }, "bind_mesh": "head" },
      { "name": "arm_left", "parent": "chest", "position": { "x": 132, "y": 280 }, "bind_mesh": "arm_left" },
      { "name": "arm_right", "parent": "chest", "position": { "x": 268, "y": 280 }, "bind_mesh": "arm_right" },
      { "name": "leg_left", "parent": "root", "position": { "x": 170, "y": 430 }, "bind_mesh": "leg_left" },
      { "name": "leg_right", "parent": "root", "position": { "x": 230, "y": 430 }, "bind_mesh": "leg_right" },
      { "name": "hat", "parent": "head", "position": { "x": 200, "y": 82 }, "bind_mesh": "hat" },
      { "name": "backpack", "parent": "chest", "position": { "x": 200, "y": 254 }, "bind_mesh": "backpack" }
    ],
    "constraints": [
      "head rotation: -15 to +15 degrees",
      "arms rotation: -35 to +35 degrees",
      "legs rotation: -22 to +22 degrees",
      "hat follows head at 80 percent",
      "backpack follows torso at 100 percent"
    ]
  },
  "animations": [
    {
      "name": "walk",
      "duration_seconds": 1.18,
      "fps": 60,
      "total_frames": 71,
      "loop": true,
      "easing": "cubic-bezier(0.42, 0, 0.28, 1) — use Rive 'Ease In Out' (custom: t1=0.42,0 t2=0.28,1)",
      "notes": [
        "Full walk cycle derived from CSS preview validation pass (2026-03-11).",
        "Rig needs upper+lower segments on arms and legs — see rig_requirements.",
        "Passing position (peak bounce) is at frame 18 and 53, not at contact frames.",
        "Arms and legs are perfectly mirrored with 35-frame (50%) offset between sides.",
        "Eyelids blink independently every ~4s, not part of walk cycle keyframes."
      ],
      "rig_requirements": [
        "root bone: Y-translate only (bodyBob). Origin at feet center.",
        "arm_upper_left + arm_upper_right: pivot at shoulder top.",
        "arm_lower_left + arm_lower_right: pivot at elbow top.",
        "leg_upper_left + leg_upper_right: pivot at hip top.",
        "leg_lower_left + leg_lower_right: pivot at knee top.",
        "foot_left + foot_right: pivot at ankle (24% x, 32% y of foot bounds).",
        "head_group: pivot at neck center.",
        "hat: pivot at brim bottom-center.",
        "backpack: pivot at strap-top center.",
        "shadow: scaleX only, no pivot needed."
      ],
      "frame_map_percent_to_frame": {
        "0%": 0,
        "25%": 18,
        "50%": 35,
        "75%": 53,
        "100_loop": 71
      },
      "keyframes": {
        "root_translateY": [
          { "frame": 0,  "value_px": 1,  "note": "contact R — slightly down" },
          { "frame": 18, "value_px": -6, "note": "passing — peak up" },
          { "frame": 35, "value_px": 1,  "note": "contact L — slightly down" },
          { "frame": 53, "value_px": -6, "note": "passing — peak up" },
          { "frame": 71, "value_px": 1,  "note": "loop = frame 0" }
        ],
        "shadow_scaleX": [
          { "frame": 0,  "scaleX": 1.03, "opacity": 0.19, "note": "contact, shadow wide" },
          { "frame": 18, "scaleX": 0.92, "opacity": 0.12, "note": "passing, shadow narrow" },
          { "frame": 35, "scaleX": 1.03, "opacity": 0.19 },
          { "frame": 53, "scaleX": 0.92, "opacity": 0.12 },
          { "frame": 71, "scaleX": 1.03, "opacity": 0.19 }
        ],
        "arm_upper_left_rotation_deg": [
          { "frame": 0,  "value": 16,  "note": "arm forward" },
          { "frame": 18, "value": 6 },
          { "frame": 35, "value": -14, "note": "arm back" },
          { "frame": 53, "value": 0 },
          { "frame": 71, "value": 16 }
        ],
        "arm_lower_left_rotation_deg": [
          { "frame": 0,  "value": 15,  "note": "forearm hangs forward" },
          { "frame": 18, "value": 8 },
          { "frame": 35, "value": -5,  "note": "forearm swings slightly behind upper arm" },
          { "frame": 53, "value": 5 },
          { "frame": 71, "value": 15 }
        ],
        "arm_upper_right_rotation_deg": [
          { "frame": 0,  "value": -14, "note": "arm back (mirror of left at frame 35)" },
          { "frame": 18, "value": -2 },
          { "frame": 35, "value": 16,  "note": "arm forward" },
          { "frame": 53, "value": 4 },
          { "frame": 71, "value": -14 }
        ],
        "arm_lower_right_rotation_deg": [
          { "frame": 0,  "value": -5,  "note": "forearm slightly behind (mirror of left at frame 35)" },
          { "frame": 18, "value": 5 },
          { "frame": 35, "value": 15,  "note": "forearm hangs forward" },
          { "frame": 53, "value": 8 },
          { "frame": 71, "value": -5 }
        ],
        "leg_upper_left_rotation_deg": [
          { "frame": 0,  "value": -22, "note": "leg back, push-off" },
          { "frame": 18, "value": -5 },
          { "frame": 35, "value": 24,  "note": "leg forward, heel strike" },
          { "frame": 53, "value": 4 },
          { "frame": 71, "value": -22 }
        ],
        "leg_lower_left_rotation_and_translate": [
          { "frame": 0,  "rotation_deg": 20,  "translateX_px": -8, "note": "bent behind, foot back" },
          { "frame": 18, "rotation_deg": 14,  "translateX_px": -3 },
          { "frame": 35, "rotation_deg": -8,  "translateX_px": 8,  "note": "extending forward for heel strike" },
          { "frame": 53, "rotation_deg": 10,  "translateX_px": 1 },
          { "frame": 71, "rotation_deg": 20,  "translateX_px": -8 }
        ],
        "leg_upper_right_rotation_deg": [
          { "frame": 0,  "value": 24,  "note": "leg forward (mirror of left at frame 35)" },
          { "frame": 18, "value": 4 },
          { "frame": 35, "value": -22, "note": "leg back, push-off" },
          { "frame": 53, "value": -5 },
          { "frame": 71, "value": 24 }
        ],
        "leg_lower_right_rotation_and_translate": [
          { "frame": 0,  "rotation_deg": -8,  "translateX_px": 8  },
          { "frame": 18, "rotation_deg": 10,  "translateX_px": 3  },
          { "frame": 35, "rotation_deg": 20,  "translateX_px": -8, "note": "bent behind" },
          { "frame": 53, "rotation_deg": 14,  "translateX_px": -2 },
          { "frame": 71, "rotation_deg": -8,  "translateX_px": 8  }
        ],
        "foot_left": [
          { "frame": 0,  "translateX_px": -20, "rotation_deg": 8,  "note": "toe-off, pointing back-down" },
          { "frame": 18, "translateX_px": -12, "rotation_deg": 2 },
          { "frame": 35, "translateX_px": 14,  "rotation_deg": -9, "note": "heel strike, foot angled up" },
          { "frame": 53, "translateX_px": 2,   "rotation_deg": 0 },
          { "frame": 71, "translateX_px": -20, "rotation_deg": 8 }
        ],
        "foot_right": [
          { "frame": 0,  "translateX_px": 14,  "rotation_deg": -9, "note": "heel strike (mirror of left at frame 35)" },
          { "frame": 18, "translateX_px": 2,   "rotation_deg": 0 },
          { "frame": 35, "translateX_px": -20, "rotation_deg": 8,  "note": "toe-off" },
          { "frame": 53, "translateX_px": -12, "rotation_deg": 2 },
          { "frame": 71, "translateX_px": 14,  "rotation_deg": -9 }
        ],
        "head_group": [
          { "frame": 0,  "translateY_px": 0,  "rotation_deg": 0 },
          { "frame": 35, "translateY_px": -3, "rotation_deg": -0.5, "note": "slight nod at opposite contact" },
          { "frame": 71, "translateY_px": 0,  "rotation_deg": 0 }
        ],
        "hat": [
          { "frame": 0,  "rotation_deg": -0.5, "translateY_px": 0 },
          { "frame": 35, "rotation_deg": 0.8,  "translateY_px": -0.5, "note": "lags behind head nod" },
          { "frame": 71, "rotation_deg": -0.5, "translateY_px": 0 }
        ],
        "backpack": [
          { "frame": 0,  "translateY_px": 0, "rotation_deg": -1 },
          { "frame": 35, "translateY_px": 2, "rotation_deg": 1,  "note": "bounces down when body is up" },
          { "frame": 71, "translateY_px": 0, "rotation_deg": -1 }
        ]
      }
    },
    {
      "name": "idle",
      "duration_seconds": 1.4,
      "notes": [
        "subtle breathing on chest and torso",
        "small head bob",
        "hat lagging slightly behind head"
      ]
    },
    {
      "name": "happy",
      "duration_seconds": 0.9,
      "notes": [
        "arms lift slightly",
        "body bounce",
        "switch to mouth_happy"
      ]
    },
    {
      "name": "sad",
      "duration_seconds": 0.9,
      "notes": [
        "head tilts downward",
        "shoulders drop",
        "switch to mouth_sad"
      ]
    },
    {
      "name": "tap_react",
      "duration_seconds": 0.25,
      "notes": [
        "quick squash and release",
        "blink during impact"
      ]
    },
    {
      "name": "enter_screen",
      "duration_seconds": 0.5,
      "notes": [
        "fade and small step-in"
      ]
    },
    {
      "name": "exit_screen",
      "duration_seconds": 0.45,
      "notes": [
        "fade and slight lean back"
      ]
    }
  ],
  "state_machine": {
    "name": "LokeStateMachine",
    "inputs": [
      "answer_correct",
      "answer_wrong",
      "user_tap",
      "screen_change"
    ],
    "states": [
      "idle",
      "happy",
      "sad",
      "tap_react",
      "enter",
      "exit"
    ]
  }
}