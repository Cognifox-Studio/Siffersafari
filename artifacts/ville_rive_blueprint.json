        },
        "bind_mesh": "body"
      },
      {
        "name": "spine",
        "parent": "root",
        "position": {
          "x": 200.0,
          "y": 350.0
        },
        "bind_mesh": "body"
      },
      {
        "name": "head",
        "parent": "spine",
        "position": {
          "x": 200.0,
          "y": 150.0
        },
        "bind_mesh": "head"
      },
      {
        "name": "arm_left",
        "parent": "spine",
        "position": {
          "x": 140.0,
          "y": 320.0
        },
        "bind_mesh": "arm_left"
      },
      {
        "name": "arm_right",
        "parent": "spine",
        "position": {
          "x": 260.0,
          "y": 320.0
        },
        "bind_mesh": "arm_right"
      },
      {
        "name": "leg_left",
        "parent": "root",
        "position": {
          "x": 170.0,
          "y": 480.0
        },
        "bind_mesh": "leg_left"
      },
      {
        "name": "leg_right",
        "parent": "root",
        "position": {
