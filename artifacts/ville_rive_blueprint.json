        },
        "bind_mesh": "antennas"
      }
    ],
    "constraints": [
      "head_follow_spine",
      "antenna_spring",
      "feet_ground_lock"
    ]
  },
  "animations": {
    "total": 14,
    "animations": [
      {
        "name": "idle",
        "category": "base",
        "duration_seconds": 1.0,
        "keyframes": [
          "breathing (scale 1.0 → 1.02)",
          "antenna sway (±5°)"
        ]
      },
      {
        "name": "idle_blink",
        "category": "base",
        "duration_seconds": 0.3,
        "keyframes": [
          "eyes: open → closed → open",
          "duration: 0.2s"
        ]
      },
      {
        "name": "idle_look_left",
        "category": "base",
        "duration_seconds": 1.0,
        "keyframes": [
          "define keyframes for idle_look_left"
        ]
      },
      {
        "name": "idle_look_right",
        "category": "base",
        "duration_seconds": 1.0,
        "keyframes": [
          "define keyframes for idle_look_right"
        ]
      },
      {
        "name": "celebrate_small",
        "category": "positive",
        "duration_seconds": 1.2,
        "keyframes": [
          "jump 20px",
          "arms up",
          "smile visible"
        ]
      },
      {
        "name": "celebrate_big",
        "category": "positive",
        "duration_seconds": 1.2,
        "keyframes": [
          "jump 50px",
          "arms wave",
          "antennas spring",
          "smile big"
        ]
      },
      {
        "name": "thumbs_up",
        "category": "positive",
        "duration_seconds": 1.0,
        "keyframes": [
          "define keyframes for thumbs_up"
        ]
      },
      {
        "name": "jump_happy",
        "category": "positive",
        "duration_seconds": 0.8,
        "keyframes": [
          "define keyframes for jump_happy"
        ]
      },
      {
        "name": "sad",
        "category": "negative",
        "duration_seconds": 1.0,
        "keyframes": [
          "head tilt down 15°",
          "arms down",
          "sad mouth visible"
        ]
      },
      {
        "name": "confused",
        "category": "negative",
        "duration_seconds": 1.0,
        "keyframes": [
          "head tilt left/right",
          "eyes narrow",
          "neutral mouth"
        ]
      },
      {
        "name": "shake_head",
        "category": "negative",
        "duration_seconds": 1.0,
        "keyframes": [
          "define keyframes for shake_head"
        ]
      },
      {
        "name": "tap_react",
        "category": "interactive",
        "duration_seconds": 0.4,
        "keyframes": [
          "scale 1.1 → 1.0",
          "slight rotate",
          "eyes wide"
        ]
      },
      {
        "name": "enter_screen",
        "category": "interactive",
        "duration_seconds": 0.6,
        "keyframes": [
          "position: x -100 → 200",
          "wave hand"
        ]
      },
      {
        "name": "exit_screen",
        "category": "interactive",
        "duration_seconds": 0.6,
        "keyframes": [
          "position: x 200 → 500",
          "wave goodbye"
        ]
      }
    ]
  },
  "state_machine": {
    "name": "VilleStateMachine",
    "initial_state": "idle",
    "inputs": [
      {
        "name": "answer_correct",
        "type": "Trigger"
      },
      {
        "name": "answer_wrong",
        "type": "Trigger"
      },
      {
        "name": "user_tap",
        "type": "Trigger"
      },
      {
        "name": "screen_change",
        "type": "Trigger"
      }
    ],
    "states": [
      {
        "name": "idle",
        "animation": "idle",
        "loop": true
      },
      {
        "name": "idle_blink",
        "animation": "idle_blink",
        "loop": false
      },
      {
        "name": "happy",
        "animation": "celebrate_small",
        "loop": false
      },
      {
        "name": "very_happy",
        "animation": "celebrate_big",
        "loop": false
      },
      {
        "name": "sad",
        "animation": "sad",
        "loop": false
      },
      {
        "name": "confused",
        "animation": "confused",
        "loop": false
      },
      {
        "name": "react_tap",
        "animation": "tap_react",
        "loop": false
      },
      {
        "name": "enter",
        "animation": "enter_screen",
        "loop": false
      },
      {
        "name": "exit",
        "animation": "exit_screen",
        "loop": false
      }
    ],
    "transitions": [
      {
        "from": "idle",
        "to": "happy",
        "trigger": "answer_correct"
      },
      {
        "from": "idle",
        "to": "sad",
        "trigger": "answer_wrong"
      },
      {
        "from": "happy",
        "to": "idle",
        "trigger": "animation_done"
      },
      {
        "from": "sad",
        "to": "idle",
        "trigger": "animation_done"
      },
      {
        "from": "idle",
        "to": "react_tap",
        "trigger": "user_tap"
      },
      {
        "from": "react_tap",
        "to": "idle",
        "trigger": "animation_done"
      },
      {
        "from": "enter",
        "to": "idle",
        "trigger": "animation_done"
      },
      {
        "from": "idle",
        "to": "exit",
        "trigger": "screen_change"
      }
    ]
  },
  "rigging_steps": [
    {
      "step": 1,
      "title": "Import SVG Assets",
      "instructions": "Import all 12 SVG files from assets/characters/ville/svg/ into Rive. Keep layer names matching file names."
    },
    {
      "step": 2,
      "title": "Create Artboard",
      "instructions": "Create artboard named 'Ville' (400×600px). Arrange layers in hierarchy: body → legs/arms → head → eyes/mouth → antennas."
    },
    {
      "step": 3,
      "title": "Add Bones",
      "instructions": "Create 9 bones: root (at feet), spine (center body), head (top of neck), arm_left, arm_right, leg_left, leg_right, antenna_left, antenna_right. Parent correctly."
    },
    {
      "step": 4,
      "title": "Bind Meshes",
      "instructions": "Use Rive's Weight Painting tool to bind each SVG mesh to appropriate bones. Arms → arm bones, legs → leg bones, head → head bone, etc."
    },
    {
      "step": 5,
      "title": "Create Animations",
      "instructions": "Create all animations from blueprint. Start with idle, idle_blink. Use timeline to keyframe bone rotations and positions."
    },
    {
      "step": 6,
      "title": "Build State Machine",
      "instructions": "Create state machine 'VilleStateMachine'. Add 4 trigger inputs: answer_correct, answer_wrong, user_tap, screen_change. Wire states per blueprint transitions."
    },
    {
      "step": 7,
      "title": "Test & Export",
      "instructions": "Test all triggers in Rive preview. Export as .riv file to assets/characters/ville/rive/ville_character.riv"
    }
  ]
}